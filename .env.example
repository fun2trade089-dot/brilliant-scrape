# Supabase Database credentials (optional, if using external DB logging)
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_key_here

# Browserbase API credentials (optional, if using remote browser environments)
BROWSERBASE_API_KEY=your_browserbase_api_key_here
BROWSERBASE_PROJECT_ID=your_browserbase_project_id_here

# Brilliant.org session tokens (required for scraping/solving locked activities)
BRILLIANT_SESSION_ID=your_session_id_cookie_value
BRILLIANT_CSRF_TOKEN=your_csrf_token_value
